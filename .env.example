# ─── Application ─────────────────────────────────────────────
APP_NAME="TAVP App"
APP_ENV=local               # local | staging | production
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=                    # generated by: tavp key:generate

# ─── Database (Lando MariaDB) ─────────────────────────────
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=tavp
DB_USERNAME=tavp
DB_PASSWORD=tavp

# ─── Mail / OTP delivery (Lando Mailpit) ────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=tavp-core-mailpit
MAIL_PORT=1025

# ─── Session & Cache ────────────────────────────────────────
SESSION_DRIVER=file         # file | redis | database
CACHE_DRIVER=file           # file | redis | apcu | memcached

# ─── Auth (TAVPid) ─────────────────────────────────────────
JWT_SECRET=                 # generated by: tavp key:generate
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
