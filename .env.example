# ─── Application ─────────────────────────────────────────────
APP_NAME="TAVP App"
APP_ENV=local               # local | staging | production
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=                    # generated by: tavp key:generate

# ─── Database ───────────────────────────────────────────────
# Supported: mysql, pgsql, sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tavp
DB_USERNAME=root
DB_PASSWORD=

# ─── Session & Cache ────────────────────────────────────────
SESSION_DRIVER=file         # file | redis | database
CACHE_DRIVER=file           # file | redis | apcu | memcached

# ─── Auth (TAVPid) ─────────────────────────────────────────
JWT_SECRET=                 # generated by: tavp key:generate
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
